---
import Layout from '../../layouts/Layout.astro';
import MarketingBody from '../../components/MarketingBody.astro';
import { content } from '../../i18n/content';
import { prefixedLangs, type Lang } from '../../i18n/config';

export function getStaticPaths() {
  return prefixedLangs.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const meta = content[lang].meta.marketing;
---
<Layout lang={lang} title={meta.title} description={meta.description} path="marketing" pageKey="marketing">
  <MarketingBody lang={lang} />
</Layout>
