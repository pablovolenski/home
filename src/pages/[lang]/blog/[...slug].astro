---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { localizedPath, formatDate, prefixedLangs, type Lang } from '../../../i18n/config';
import { content } from '../../../i18n/content';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of prefixedLangs) {
    const posts = await getCollection('blog', ({ data }) => data.lang === lang && !data.draft);
    for (const post of posts) {
      paths.push({
        params: { lang, slug: post.slug.replace(new RegExp(`^${lang}/`), '') },
        props: { post },
      });
    }
  }
  return paths;
}

const lang = Astro.params.lang as Lang;
const { post } = Astro.props;
const { Content } = await post.render();
const t = content[lang];
const slug = post.slug.replace(new RegExp(`^${lang}/`), '');
---
<Layout
  lang={lang}
  title={`${post.data.title} — ${t.brand}`}
  description={post.data.description ?? post.data.title}
  path={`blog/${slug}`}
  pageKey="blog"
>
  <section class="page-section">
    <div class="wrap">
      <a class="back-link" href={localizedPath(lang, 'blog')}>{t.blog.back}</a>
      <article class="post">
        <div class="post-meta">{formatDate(post.data.pubDate, lang)}</div>
        <h1>{post.data.title}</h1>
        <div class="content">
          <Content />
        </div>
      </article>
    </div>
  </section>
</Layout>
