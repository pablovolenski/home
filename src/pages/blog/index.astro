---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout
  title="Blog — Independent Practice"
  description="Notes on web presence, marketing and building things that stay yours."
>
  <section class="page-section">
    <div class="wrap">
      <p class="eyebrow tight">// blog</p>
      <h2>Notes &amp; write-ups</h2>
      <div class="post-list">
        {posts.map((post) => (
          <a class="post-item" href={`/blog/${post.slug}/`}>
            <div>
              <div class="title">{post.data.title}</div>
              {post.data.description && <p class="excerpt">{post.data.description}</p>}
            </div>
            <div class="date">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
          </a>
        ))}
        {posts.length === 0 && <p class="intro">No posts yet — check back soon.</p>}
      </div>
    </div>
  </section>
</Layout>
